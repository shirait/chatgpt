<%= @message_thread.title %><br>

<% @message_thread.messages.each do |message| %>
  <div class="<%= "#{message.message_type.to_s}-message" %>">
    <%= simple_format(message.content) %>
  </div>
<% end %>

新規メッセージ
<%= form_with(model: @message, url: add_message_message_thread_path(@message_thread), method: :post) do |f| %>
  <%= f.label(:content) %>
  <%= f.text_field(:content) %>
  <%= f.submit("Create Message") %>
<% end %>


