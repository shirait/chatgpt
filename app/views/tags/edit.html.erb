<%= form_with(model: @tag, url: tag_path(@tag), method: :put, local: true) do |f| %>
  <%= render("form", f: f) %>
  <%= f.submit(t("common.update"), class: "button is-primary is-normal mt-1") %>
<% end %>

<%= link_to "一覧に戻る", tags_path, class: "button is-warning is-normal mt-1" %>
<%= link_to "詳細に戻る", tag_path(@tag), class: "button is-warning is-normal mt-1" if @tag.persisted? %>