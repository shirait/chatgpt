<div class="box">
  <%= @gpt_model.name %>
  <%= @gpt_model.description %>
  <%= @gpt_model.active? ? t("activerecord.attributes.gpt_model.active") : t("activerecord.attributes.gpt_model.inactive") %>
  <%= link_to(t("common.edit"), edit_gpt_model_path(@gpt_model), class: 'button is-primary is-light is-normal') %>
  <%= link_to(t("common.delete"), gpt_model_path(@gpt_model), class: 'button is-danger is-light is-normal', data: { confirm: t("common.delete_confirm"), method: 'delete' }) %>
  <%= link_to(t("common.back"), gpt_models_path, class: 'button is-warning is-light is-normal') %>
</div>