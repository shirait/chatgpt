<% @gpt_models.each do |gpt_model| %>
  <div class="box">
    <h2 class="title is-4"><%= gpt_model.name %></h2>
    <p class="subtitle is-6"><%= gpt_model.description %></p>
    <p><%= gpt_model.active? ? 'アクティブ' : '非アクティブ' %></p>
    <%= link_to '編集', edit_gpt_model_path(gpt_model), class: 'button is-primary is-light is-normal' %>
    <%= link_to '削除', gpt_model_path(gpt_model), class: 'button is-danger is-light is-normal', data: { confirm: '本当に削除しますか？', method: 'delete' } %>
    <%= link_to '詳細', gpt_model_path(gpt_model), class: 'button is-info is-light is-normal' %>
  </div>
<% end %>

<%= link_to '新規作成', new_gpt_model_path, class: 'button is-primary is-light is-normal' %>
