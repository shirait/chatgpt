<div class="field">
  <%= f.label(:name, class: "label") %>
  <%= f.text_field(:name, class: "input", placeholder: "GPTモデルの名前を入力。間違えるとOpanAI APIへのリクエストに失敗するのでご注意ください。") %>
</div>
<div class="field">
  <%= f.label(:description, class: "label") %>
  <%= f.text_area(:description, class: "textarea") %>
</div>
<div class="field">
  <%= f.label(:active, class: "label") do %>
    <%= f.check_box(:active, class: "checkbox") %>
    <%= t("activerecord.attributes.gpt_model.active") %>
  <% end %>
  <p class="help">
    有効を設定したモデルがOpenAI APIにリクエストされます。
    このモデルで有効を選択すると、他のモデルは全て無効になります。
  </p>
</div>
<div class="field">
  <%= f.submit(class: "button is-primary is-normal mt-1") %>
  <%= link_to "一覧に戻る", admin_gpt_models_path, class: "button is-warning is-normal mt-1" %>
  <%= link_to "詳細に戻る", admin_gpt_model_path(@gpt_model), class: "button is-warning is-normal mt-1" if @gpt_model.persisted? %>
</div>
