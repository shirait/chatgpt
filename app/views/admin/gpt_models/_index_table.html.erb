<div class="table-container">
  <table class="table is-bordered is-hoverable is-narrow">
    <thead>
      <tr>
        <th class="has-text-centered">ID</th>
        <th class="has-text-centered"><%= t("activerecord.attributes.gpt_model.name") %></th>
        <th class="has-text-centered"><%= t("activerecord.attributes.gpt_model.description") %></th>
        <th class="has-text-centered"><%= t("activerecord.attributes.gpt_model.status") %></th>
        <th class="has-text-centered"><%= t("common.operation") %></th>
      </tr>
    </thead>
    <tbody>
    <tfoot>
      <% @gpt_models.each do |gpt_model| %>
        <tr>
          <td><%= gpt_model.id %></td>
          <td><%= gpt_model.name %></td>
          <td><%= simple_format(gpt_model.description) %></td>
          <td class="has-text-centered"><%= active_icon(gpt_model) %></td>
          <td>
            <%= link_to(t("common.show"), admin_gpt_model_path(gpt_model), class: 'button is-info is-light is-normal') %>
            <%= link_to(t("common.edit"), edit_admin_gpt_model_path(gpt_model), class: 'button is-primary is-light is-normal') %>
            <%= link_to(t("common.delete"), admin_gpt_model_path(gpt_model), class: 'button is-danger is-light is-normal', data: { turbo_method: :delete, turbo_confirm: '本当に削除しますか？' }) %>
          </td>
        </tr>
      <% end %>
    </tfoot>
  </table>
</div>
