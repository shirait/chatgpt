<% # review: エラーメッセージは各フォームの近くに書く %>
<% if nil # @user.errors.any? %>
  <div class="notification is-danger">
    <ul>
      <% @user.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="field">
  <%= f.label(:name, class: "label") %>
  <%= f.text_field(:name, class: "input", placeholder: "ユーザー名") %>
  <% if @user.errors[:name].present? %>
    <p class="help is-danger"><%= @user.errors[:name].join(", ") %></p>
  <% end %>
</div>

<div class="field">
  <%= f.label(:email, class: "label") %>
  <%= f.email_field(:email, class: "input", placeholder: "メールアドレス") %>
  <% if @user.errors[:email].present? %>
    <p class="help is-danger"><%= @user.errors[:email].join(", ") %></p>
  <% end %>
</div>

<div class="field">
  <%= f.label(:password, class: "label") %>
  <%= f.password_field(:password, class: "input", placeholder: "パスワード（6文字以上128文字以内）") %>
  <% if @user.errors[:password].present? %>
    <p class="help is-danger"><%= @user.errors[:password].join(", ") %></p>
  <% end %>
  <% if @user.persisted? %>
    <p class="help">編集時は変更する場合のみ入力してください。</p>
  <% end %>
</div>

<div class="field">
  <%= f.label(:password_confirmation, class: "label") %>
  <%= f.password_field(:password_confirmation, class: "input", placeholder: "パスワード確認") %>
  <% if @user.errors[:password_confirmation].present? %>
    <p class="help is-danger"><%= @user.errors[:password_confirmation].join(", ") %></p>
  <% end %>
</div>

<div class="field">
  <%= f.label(:role, class: "label") %>
  <div class="select">
    <%= f.select(:role, User.roles.keys.map { |k| [t("activerecord.attributes.user.#{k}"), k] }, {}, { class: "select" }) %>
  </div>
  <% if @user.errors[:role].present? %>
    <p class="help is-danger"><%= @user.errors[:role].join(", ") %></p>
  <% end %>
</div>

<div class="field">
  <%= f.label(:active, class: "label") do %>
    <%= f.check_box(:active, class: "checkbox") %>
    <%= t("activerecord.attributes.user.active") %>
  <% end %>
</div>

<div class="field">
  <%= f.submit(class: "button is-primary is-normal mt-1") %>
  <%= link_to t("common.back"), admin_users_path, class: "button is-warning is-normal mt-1" %>
</div>

