<%= link_to '新規作成', new_admin_user_path, class: 'button is-primary is-light is-normal mb-4' %>

<div class="box">
  <h1 class="title">ユーザー詳細</h1>

  <div class="field">
    <label class="label">ID</label>
    <div class="control">
      <p><%= @user.id %></p>
    </div>
  </div>

  <div class="field">
    <label class="label"><%= t("activerecord.attributes.user.name") %></label>
    <div class="control">
      <p><%= @user.name %></p>
    </div>
  </div>

  <div class="field">
    <label class="label"><%= t("activerecord.attributes.user.email") %></label>
    <div class="control">
      <p><%= @user.email %></p>
    </div>
  </div>

  <div class="field">
    <label class="label"><%= t("activerecord.attributes.user.role") %></label>
    <div class="control">
      <p><%= t("activerecord.attributes.user.role.#{@user.role}") %></p>
    </div>
  </div>

  <div class="field">
    <label class="label"><%= t("activerecord.attributes.user.status") %></label>
    <div class="control"><%= active_icon(@user) %></div>
  </div>

  <div class="field">
    <%= link_to(t("common.edit"), edit_admin_user_path(@user), class: 'button is-primary is-light is-normal') %>
    <%= link_to("一覧に戻る", admin_users_path, class: 'button is-warning is-light is-normal') %>
  </div>
</div>

