<% # 検索フォーム %>
<%= form_with(url: search_admin_users_path, method: :get, local: true, class: "box mb-4") do |f| %>
  <div class="field is-grouped">
    <div class="control is-expanded">
      <%= f.label(:name, t("activerecord.attributes.user.name"), class: "label") %>
      <%= f.text_field(:name, class: "input", placeholder: "名前", value: params[:name]) %>
    </div>
    <div class="control is-expanded">
      <%= f.label(:email, t("activerecord.attributes.user.email"), class: "label") %>
      <%= f.text_field(:email, class: "input", placeholder: "メールアドレス", value: params[:email]) %>
    </div>
  </div>
  <div class="field is-grouped">
    <div class="control is-expanded">
      <%= f.label(:role, t("activerecord.attributes.user.role"), class: "label") %>
      <div class="select">
        <%= f.select(:role, user_role_select_options, { include_blank: true, selected: params[:role] }, { class: "select" }) %>
      </div>
    </div>
    <div class="control is-expanded">
      <%= f.label(:active, t("activerecord.attributes.user.status"), class: "label") %>
      <div class="select">
        <%= f.select(:active, { t("activerecord.attributes.user.active") => "1", t("activerecord.attributes.user.inactive") => "0" }, { include_blank: true, selected: params[:active] }, { class: "select" }) %>
      </div>
    </div>
  </div>
  <%= f.submit(t("common.search"), class: "button is-primary is-light is-normal") %>
<% end %>

<%= link_to '新規作成', new_admin_user_path, class: 'button is-primary is-light is-normal mb-4' %>

<% # ユーザー一覧(テーブル表示) %>
<%= render("index_table", users: @users) %>
