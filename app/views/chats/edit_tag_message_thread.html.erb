<%= form_with(model: @message_thread, url: update_tag_message_thread_chat_path(@message_thread), method: :post) do |f| %>
  <div class="checkboxes">
    <%= f.collection_check_boxes(:tag_ids, @tags, :id, :name) do |b| %>
      <div class="checkbox">
        <%= b.check_box %>
        <%= b.label %>
      </div>
      <br>
    <% end %>
  </div>
  <%= f.submit(t("common.update"), class: "button is-primary is-normal mt-1") %>
<% end %>
<%= link_to(t("common.back"), chat_path(@message_thread), class: "button is-warning is-normal mt-1") %>