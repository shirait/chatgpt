  <% if @user_message.errors[:content].present? %>
    <div class="notification is-danger is-small">
      <%= "Content: #{@user_message.errors[:content].join(", ")}" %>
    </div>
  <% end %>
  <div class="message-content-input">
    <%= f.text_area(:content, placeholder: '質問を入力してください', class: "textarea", rows: 5) %>
  </div>
  <div>
    <%= f.submit('送信する', class: "button is-primary is-normal") %>
  </div>
