<% @message_thread.messages.each do |message| %>
  <% flex_direction = message.user? ? "is-flex-direction-row-reverse" : "" %>
  <div style="" class="is-flex <%= flex_direction %>" data-message-id="<%= message.id %>">
    <div class="<%= message_type_class(message) %>">
      <div class="box">
        <%= markdown_to_html(message.content) %>
        <%= hidden_field_tag("message-#{message.id}", message.content) %>
        <% if message.message_files.attached? %>
          <% message.message_files.each do |message_file| %>
            <% if message_file.content_type&.start_with?("image/") %>
              <%= image_tag(url_for(message_file), class: "message-file") %>
            <% else %>
              <%= link_to message_file.filename.to_s,
                          url_for(message_file),
                          target: "_blank",
                          rel: "noopener" %>
            <% end %>
          <% end %>
        <% end %>
      </div>
      <div class="copy">
        <%= link_to(
          "#",
          onclick: "copyButton('message-#{message.id}'); return false;"
          ) do %>
          <i class="fa fa-copy"></i>
          <span><%= t("common.copy") %></span>
        <% end %>
        <%= content_tag(:span, t("common.copied"), id: "copy-message-#{message.id}", style: "color:red; display: none;") %>
      </div>
    </div>
  </div>
<% end %>

<%# リアルタイム表示用のアシスタントメッセージ領域 %>
<div id="streaming-message-container" style="display: none;">
  <div class="is-flex">
    <div class="assistant-message">
      <div class="box">
        <div id="streaming-message-content"></div>
      </div>
    </div>
  </div>
</div>

<%= form_with(model: @user_message, url: add_message_chat_path(@message_thread), method: :post, html: { class: "new-message-form" }) do |f| %>
  <%= render('form', f: f) %>
<% end %>

<%= link_to(t('common.edit_title'), edit_chat_path(@message_thread), class: "button is-primary is-light is-normal mt-1") %><br>
<%= link_to(
  t("common.delete"),
  chat_path(@message_thread),
  class: 'delete-link button is-danger is-light is-normal mt-1',
  data: { confirm: t("common.delete_confirm"), method: 'delete' }
) %>

<script type="module">
  import ChatChannel from "channels/chat_channel"
  import { marked } from "marked"

  // marked.jsの設定（サーバーサイドのredcarpetと同様の設定を目指す）
  marked.setOptions({
    breaks: true, // 改行を<br>に変換
    gfm: true, // GitHub Flavored Markdownを有効化
    headerIds: false, // ヘッダーIDを無効化（シンプルに）
    mangle: false
  })

  function copyButton(messageId) {
    // クリップボードにコピーする
    const text = $('#' + messageId).val();
    navigator.clipboard.writeText(text);

    // 「コピーしました！」の文言を表示する。
    var copy_message = $('#copy-' + messageId);
    copy_message.show();
    $(copy_message).fadeOut(2000);
  }

  // ページ読み込み時に最後の回答にスクロール（画像の読み込み完了を待つ）
  function scrollToLastMessage() {
    var last_message = $('.assistant-message:last');
    if (last_message.length === 0) {
      return;
    }

    var position = last_message.offset().top;
    $("html,body").animate({
      scrollTop: position - 70
    }, 100);
  }

  <% if use_http_call? %>
    $(document).ready(function() {
      var images = $('.message-file');
      var imagesToLoad = images.length;

      if (imagesToLoad === 0) {
        // 画像がない場合は即座にスクロール
        scrollToLastMessage();
        return;
      }

      // すべての画像の読み込み完了を待つ
      var loadedCount = 0;
      images.on('load', function() {
        loadedCount++;
        if (loadedCount === imagesToLoad) {
          scrollToLastMessage();
        }
      }).on('error', function() {
        // エラー時もカウントに含める
        loadedCount++;
        if (loadedCount === imagesToLoad) {
          scrollToLastMessage();
        }
      });

      // 既に読み込まれている画像がある場合のフォールバック
      images.each(function() {
        if (this.complete) {
          loadedCount++;
        }
      });

      if (loadedCount === imagesToLoad) {
        scrollToLastMessage();
      }
    });
  <% else %>
    // DOM読み込み完了後、少し遅延してスクロール（画像読み込みを待つ）
    $(document).ready(function() {
      // 即座に実行
      setTimeout(scrollToLastMessage, 100);
      // 画像読み込み完了後にも実行（念のため）
      $(window).on('load', function() {
        setTimeout(scrollToLastMessage, 50);
      });

      // ActionCable接続
      const messageThreadId = <%= @message_thread.id %>;
      let streamingContent = "";
      let streamingMessageContainer = null;
      let streamingMessageContent = null;

      const chatChannel = new ChatChannel(
        messageThreadId,
        // onMessageChunk
        (chunk) => {
          if (!streamingMessageContainer) {
            streamingMessageContainer = document.getElementById('streaming-message-container');
            streamingMessageContent = document.getElementById('streaming-message-content');
            streamingMessageContainer.style.display = 'block';
            streamingContent = "";
          }
          streamingContent += chunk;
          // マークダウンをHTMLに変換して表示
          try {
            const html = marked.parse(streamingContent);
            streamingMessageContent.innerHTML = html;
          } catch (e) {
            // マークダウンのパースエラー時はテキストとして表示
            streamingMessageContent.textContent = streamingContent;
          }
          // 自動スクロール
          streamingMessageContainer.scrollIntoView({ behavior: 'smooth', block: 'end' });
        },
        // onMessageComplete
        () => {
          if (streamingMessageContainer) {
            // ページをリロードして最終的なメッセージを表示（サーバーサイドでレンダリングされたもの）
            window.location.reload();
          }
        },
        // onMessageError
        (error) => {
          if (streamingMessageContainer) {
            streamingMessageContainer.style.display = 'none';
            alert(error);
          } else {
            alert(error);
          }
          // エラー時もページをリロード
          setTimeout(() => {
            window.location.reload();
          }, 1000);
        }
      );

      chatChannel.connect();

      // ページ離脱時に切断
      window.addEventListener('beforeunload', () => {
        chatChannel.disconnect();
      });
    });
  <% end %>
</script>
