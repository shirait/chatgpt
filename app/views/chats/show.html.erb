<% @message_thread.messages.each do |message| %>
  <% flex_direction = message.user? ? "is-flex-direction-row-reverse" : "" %>
  <div style="" class="is-flex <%= flex_direction %>">
    <div class="<%= message_type_class(message) %>">
      <div class="box">
        <%= simple_format(message.content) %>
        <%= hidden_field_tag("message-#{message.id}", message.content) %>
      </div>
      <div class="copy">
        <%= link_to(
          "コピー",
          "#",
          onclick: "copyButton('message-#{message.id}'); return false;",
          class: "fa fa-copy")
        %>
      </div>
    </div>
  </div>
<% end %>

<%= form_with(model: @user_message, url: add_message_chat_path(@message_thread), method: :post, html: { class: "new-message-form" }) do |f| %>
  <%= render('form', f: f) %>
<% end %>

<%= link_to('スレッドタイトルを編集する', edit_chat_path(@message_thread)) %><br>
<%= link_to(
  'スレッドを削除する',
  chat_path(@message_thread),
  class: 'delete-link',
  data: { confirm: '本当に削除しますか？', method: 'delete' }
) %>

<script>
  // ページ読み込み時に最下行にスクロール
  function scrollToBottom() {
    const mainContent = document.querySelector('.main-content');
    if (mainContent) {
      mainContent.scrollTo({
        top: mainContent.scrollHeight,
        behavior: 'smooth'
      });
    } else {
      // フォールバック: メインコンテンツが見つからない場合は通常のスクロール
      window.scrollTo({
        top: document.documentElement.scrollHeight,
        behavior: 'instant'
      });
    }
  }

  // DOMContentLoadedイベントで実行
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', scrollToBottom);
  } else {
    // すでに読み込み済みの場合は即座に実行
    scrollToBottom();
  }

  // Turboを使っている場合のイベント
  document.addEventListener('turbo:load', scrollToBottom);

  <%# setupDeleteLinksは application.html.erb で共通化済み %>

  // コピー実行
  // todo: コピーを実行したら文言を「コピーしました」に変更したい。
  function copyButton(messageId) {
    const message = document.getElementById(messageId);
    const text = message.value;
    navigator.clipboard.writeText(text);
  }
</script>
