import ChatChannel from "channels/chat_channel"
import { marked } from "marked"

<% # marked.jsの設定（サーバーサイドのredcarpetと同様の設定を目指す） %>
marked.setOptions({
  <% # 改行を<br>に変換 %>
  breaks: true,
  <% # GitHub Flavored Markdownを有効化 %>
  gfm: true,
  <% # ヘッダーIDを無効化（シンプルに） %>
  headerIds: false,
  mangle: false
})

$(document).ready(function() {
  <% # DOM読み込み完了後、少し遅延してスクロール（画像読み込みを待つ） %>
  <% # 即座に実行 %>
  setTimeout(scrollToLastMessage, 100);
  <% # 画像読み込み完了後にも実行（念のため） %>
  $(window).on('load', function() {
    setTimeout(scrollToLastMessage, 50);
  });

  <% # ActionCable接続 %>
  const messageThreadId = <%= @message_thread.id %>;
  let streamingContent = "";
  <% # ストリーミング中のチャンクのインデックス。これを使って表示順を整理しないと、「チャット」という文字列を受け取ったのに「チャトッ」等と表示される可能性がある。 %>
  let expectedChunkIndex = 0;
  const chunkBuffer = new Map();
  let streamingMessageContainer = null;
  let streamingMessageContent = null;

  <% # ChatChannelのインスタンス作成 %>
  const chatChannel = new ChatChannel(
    <% # 第一引数。(スレッドID) %>
    messageThreadId,
    <% #  第二引数。途中の文字列を受信したときの処理(onMessageChunk) %>
    <% # OpenAiChatCallerWebsocket#broadcast_message_chunk から呼び出される。 %>
    (chunk, index) => {
      if (!streamingMessageContainer) {
        streamingMessageContainer = document.getElementById('streaming-message-container');
        streamingMessageContent = document.getElementById('streaming-message-content');
        streamingMessageContainer.style.display = 'block';
        streamingContent = "";
        expectedChunkIndex = 0;
        chunkBuffer.clear();
      }
      if (typeof index !== 'number') {
        streamingContent += chunk;
      } else {
        chunkBuffer.set(index, chunk);
        while (chunkBuffer.has(expectedChunkIndex)) {
          streamingContent += chunkBuffer.get(expectedChunkIndex);
          chunkBuffer.delete(expectedChunkIndex);
          expectedChunkIndex += 1;
        }
      }
      <% # マークダウンをHTMLに変換して表示 %>
      try {
        const html = marked.parse(streamingContent);
        streamingMessageContent.innerHTML = html;
      } catch (e) {
        <% # マークダウンのパースエラー時はテキストとして表示 %>
        streamingMessageContent.textContent = streamingContent;
      }
      <% # 自動スクロール %>
      streamingMessageContainer.scrollIntoView({ behavior: 'smooth', block: 'end' });
    },
    <% # 第三引数。完了通知が来た時の処理(onMessageComplete) %>
    <% # OpenAiChatCallerWebsocket#broadcast_message_complete から呼び出される。 %>
    () => {
      if (streamingMessageContainer) {
        <% # ページをリロードして最終的なメッセージを表示（サーバーサイドでレンダリングされたもの） %>
        window.location.reload();
      }
    },
    <% # 第四引数。エラー通知が来た時の処理(onMessageError) %>
    <% # OpenAiChatCallerWebsocket#broadcast_message_error から呼び出される。 %>
    (error) => {
      if (streamingMessageContainer) {
        streamingMessageContainer.style.display = 'none';
        alert(error);
      } else {
        alert(error);
      }
      <% # エラー時もページをリロード %>
      setTimeout(() => {
        window.location.reload();
      }, 1000);
    }
  );

  chatChannel.connect();

  <% # ページ離脱時に切断 %>
  window.addEventListener('beforeunload', () => {
    chatChannel.disconnect();
  });
});
