$(document).ready(function() {
  var images = $('.message-file');
  var imagesToLoad = images.length;

  if (imagesToLoad === 0) {
    // 画像がない場合は即座にスクロール
    scrollToLastMessage();
    return;
  }

  // すべての画像の読み込み完了を待つ
  var loadedCount = 0;
  images.on('load', function() {
    loadedCount++;
    if (loadedCount === imagesToLoad) {
      scrollToLastMessage();
    }
  }).on('error', function() {
    // エラー時もカウントに含める
    loadedCount++;
    if (loadedCount === imagesToLoad) {
      scrollToLastMessage();
    }
  });

  // 既に読み込まれている画像がある場合のフォールバック
  images.each(function() {
    if (this.complete) {
      loadedCount++;
    }
  });

  if (loadedCount === imagesToLoad) {
    scrollToLastMessage();
  }
});
