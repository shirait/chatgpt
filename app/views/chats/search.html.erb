<%= form_with(url: search_chats_path, method: :get, local: true) do |f| %>
  <div class="field">
    <%= f.label(:search, "文字列で検索", class: "label") %>
    <%= f.text_field(:search, class: "input", value: params[:search]) %>
  </div>

  <%= f.label(:tag_id, "タグで絞り込み", class: "label") %>
  <div class="select">
    <%= f.select(:tag_id, options_from_collection_for_select(@tags_for_search, :id, :name, params[:tag_id]), include_blank: "", class: "", value: params[:tag_id]) %>
  </div>

  <div class="field">
    <%= f.submit("検索", class: "button is-primary is-normal mt-4") %>
  </div>
<% end %>

<br>
<% if @searched_message_threads.present? %>
  <% if @searched_tag.present? %>
    「<%= @searched_tag.name %>」のタグが付いたチャットは以下になります。
  <% else %>
    検索にヒットしたチャットは以下になります。
  <% end %>

  <% @searched_message_threads.each do |message_thread| %>
    <div>
      <%= link_to(message_thread.title, chat_path(message_thread)) %>
    </div>
  <% end %>
<% else %>
  <% if @searched_tag.present? %>
    「<%= @searched_tag.name %>」のタグが付いたチャットはありませんでした。
  <% else %>
    検索にヒットしたチャットはありませんでした。
  <% end %>
<% end %>
